;+
; NAME:
;     mc_fitlinecoeffs1d
;
; PURPOSE:
;     To fit line coeffiecients as a function of position on the array
;
; CALLING SEQUENCE:
;     mc_fitlinecoeffs1d,lstruc,fitdeg,c1coeff,c2coeff,QAPLOT=qaplot, $
;                        MODEINFO=modeinfo,CANCEL=cancel
;
; INPUTS:
;     lstruc - A structure giving ... generated by ....
;     fitdeg - A 2 element array giving the polynomial degree of the
;              fit in the x or column direction and the y or row
;              direction.
;
; OPTIONAL INPUTS:
;     None
;
; KEYWORD PARAMETERS:
;     QAPLOT   - If given, a Quality Assurance plot will be generated.
;                QAPLOT is a structure with the following tags:
;
;                ncols  = the number of columns in the array (scalar)
;                nrows  = the number of rows in the array (scalar)
;                prefix = the prefix of the file (scalar)
;                xrange = a 2-element array given the minumum and
;                         maximum column extent of *all* the orders 
;
;     MODEINFO - If given, 
;
;
;     CANCEL   - Set on return if there is a problem.
;
; OUTPUTS:
;
;
; OPTIONAL OUTPUTS:
;      None
;
; COMMON BLOCKS:
;      None
;
; RESTRICTIONS:
;      None
;
; DEPENDENCIES:
;     Spextool package (and its dependencies)
;
; PROCEDURE:
;
;
; EXAMPLES:
;
;
; MODIFICATION HISTORY:
;       2017-08-13:  Written by M. Cushing, University of Toledo
;-
;
;===============================================================================
;
pro fitlinecoeffs_plotlines,ytop,ybot,lc

;  Plot the adjust lines

  nlines = n_elements(ytop)
  
;  Now plot the lines themselves
     
     sx = 0
     sy = 0
     so = 0
     
     for i = 0,nlines-1 do begin
        
        del = ytop[i]-ybot[i]
        ny = ceil(del)
        ys = findgen(ny+1)-float(ny)/2.
        xs = poly(ys,lc[*,i])

        sx = [sx,xs]
        sy = [sy,ys]
        
     endfor
     
     sx = sx[1:*]
     sy = sy[1:*]
     
     yrange = [min(sy,MAX=ymax),ymax]
     xrange = [min(sx,MAX=xmax),xmax]

     pos = mc_gridplotpos([0.1,0.1,0.95,0.95],[1,1],0.02,/SQUARE)
     plot,[1],[1],/NODATA,XRANGE=mc_bufrange(xrange,0.05), $
          YRANGE=mc_bufrange(yrange,0.05),FONT=0,POSITION=pos[*,0],$
          XTITLE='!9D!Xx (pixels)',YTITLE='!9D!Xy (pixels)',/XSTY,/YSTY,$
          TITLE='Zeroed Lines'

           plotsym,0,0.4,/FILL
           oplot,sx,sy,PSYM=8
     
     
  end
;
;===============================================================================
;
pro fitlinecoeffs_plotfit,xmid,c,c_coeff,fit_c,ogoodbad_c,coefficent

  pos = mc_gridplotpos([0.1,0.1,0.95,0.95],[1,2],0.03)

;  Plot the actual fit
  
  yrange = mc_bufrange([min(c,MAX=max),max],0.05)  
  min = min(xmid,MAX=max)
  xrange = mc_bufrange([min,max],0.05)


  plot,xmid,c,/XSTY,/YSTY,POSITION=pos[*,0],FONT=0,/NODATA,$
       XRANGE=xrange,YRANGE=yrange,YTITLE=coefficent, $
       XTICKNAME=replicate(' ',10)

  x = indgen(max-min+1)+min
  oplot,x,poly(x,c_coeff)
  
  plotsym,0,1.2,/FILL  
  oplot,xmid,c,PSYM=8  
  plotsym,0,0.9,/FILL
  oplot,xmid,c,PSYM=8,COLOR=2

  z = where(ogoodbad_c eq 0,cnt)
  if cnt ne 0 then begin

     oplot,xmid[z],c[z],PSYM=6,SYMSIZE=2       

  endif

;  Plot the residuals

  del = (c-fit_c)/fit_c*100
  yrange = mc_bufrange([min(del,MAX=max),max],0.05)    
  
  plot,xmid,del,/XSTY,/YSTY,POSITION=pos[*,1],/NOERASE,FONT=0,/NODATA,$
       XRANGE=xrange,YRANGE=yrange,YTITLE='Percent Fractional Residual of '+ $
       coefficent,XTITLE='Column (pixels)'

  plots,!x.crange,[0,0],LINESTYLE=1
  
  plotsym,0,1.2,/FILL  
  oplot,xmid,del,PSYM=8  
  plotsym,0,0.9,/FILL
  oplot,xmid,del,PSYM=8,COLOR=2

  z = where(ogoodbad_c eq 0,cnt)
  if cnt ne 0 then begin

     oplot,xmid[z],del[z],PSYM=6,SYMSIZE=2       

  endif  


end
;
;===============================================================================
;
pro mc_fitlinecoeffs1d,lstruc,fitdeg,c1coeff,c2coeff,WEIGHT=weight, $
                       QAPLOT=qaplot,MODEINFO=modeinfo,CANCEL=cancel

  cancel = 0

;  Get some useful information
  
  lc = lstruc.linecoeffs
  linedeg = n_elements(lc[*,0])-1

  nlines = n_elements(lstruc)
  order  = lstruc.order
  orders = order[uniq(order,sort(order))]
  norders = n_elements(orders)
  
  xbot   = lstruc.xbot
  ybot   = lstruc.ybot
  xtop   = lstruc.xtop
  ytop   = lstruc.ytop
  xmid   = lstruc.xmid
  ymid   = lstruc.ymid
  
;  Correct the line coefficients relative to the middle of the slit
  
  for i = 0,nlines-1 do begin

        case linedeg of

           1: tmp = [0,lc[1,i]]
           
           2: tmp = [0,lc[1,i]+2*lc[2,i]*ymid[i],lc[2,i]]
                      
        endcase
        
        lc[*,i] = reform(tmp)
        
  endfor
  
;  Fit the c1 coefficient
  
  c1 = reform((lc)[1,*])

  c1coeff = mc_robustpoly1d(xmid,c1,fitdeg[0],3.5,0.01,/SILENT, $
;                            ZERR=weight,$
                            OGOODBAD=ogoodbad_c1)
  fit_c1 = mc_poly1d(xmid,c1coeff)

;  Now fit the c2 coefficient if provided
  
  if linedeg eq 2 then begin
     
     c2 = reform((lc)[2,*])
     c2coeff = mc_robustpoly2d(xmid,c2,fitdeg[1],3.5,0.01, $
                               ZERR=weight,/SILENT,OGOODBAD=ogoodbad_c2)
     fit_c2 = mc_poly2d(xmid,fitdeg[1],c2coeff)
     
  endif

;  Get set up for the QA plots if requested
  
  if keyword_set(QAPLOT) then begin

;     c1label = 'deg!DX!N='+strtrim(fitdeg[0],2)+', deg!DY!N='+ $
;               strtrim(fitdeg[1],2)
              
;  Set up the postscript
     
     !x.thick=3
     !y.thick=3
     !p.thick=3

     mc_mkct
     mc_setpsdev,qaplot.prefix+'_1DCoeffFits.ps',11,8.5,/LANDSCAPE, $
                 FONT=13

;  Plot the lines
     
     fitlinecoeffs_plotlines,ytop,ybot,lc

     fitlinecoeffs_plotfit,xmid,c1,c1coeff,fit_c1,ogoodbad_c1,'c1!Dzline!N'
     
     
     mc_setpsdev,/CLOSE,/CONVERT,/ERASE

  endif
  
 
end
