;+
; NAME:
;     mc_fitlinecoeffs2d
;
; PURPOSE:
;     To fit line coeffiecients as a function of position on the array
;
; CALLING SEQUENCE:
;     mc_fitlinecoeffs2d,lstruc,fitdeg,c1coeff,c2coeff,QAPLOT=qaplot, $
;                        MODEINFO=modeinfo,CANCEL=cancel
;
; INPUTS:
;     lstruc - A structure giving ... generated by ....
;     fitdeg - A 2 element array giving the polynomial degree of the
;              fit in the x or column direction and the y or row
;              direction.
;
; OPTIONAL INPUTS:
;     None
;
; KEYWORD PARAMETERS:
;     QAPLOT   - If given, a Quality Assurance plot will be generated.
;                QAPLOT is a structure with the following tags:
;
;                ncols  = the number of columns in the array (scalar)
;                nrows  = the number of rows in the array (scalar)
;                prefix = the prefix of the file (scalar)
;                xrange = a 2-element array given the minumum and
;                         maximum column extent of *all* the orders 
;
;     MODEINFO - If given, 
;
;
;     CANCEL   - Set on return if there is a problem.
;
; OUTPUTS:
;
;
; OPTIONAL OUTPUTS:
;      None
;
; COMMON BLOCKS:
;      None
;
; RESTRICTIONS:
;      None
;
; DEPENDENCIES:
;     Spextool package (and its dependencies)
;
; PROCEDURE:
;
;
; EXAMPLES:
;
;
; MODIFICATION HISTORY:
;       2017-08-13:  Written by M. Cushing, University of Toledo
;-
;
;===============================================================================
;
pro fitlinecoeffs_plotlines,ytop,ybot,order,lc,orders

;  Plot the adjust lines

  nlines = n_elements(ytop)
  norders = n_elements(orders)
  
;  Now plot the lines themselves
     
     sx = 0
     sy = 0
     so = 0
     
     for i = 0,nlines-1 do begin
        
        del = ytop[i]-ybot[i]
        ny = ceil(del)
        ys = findgen(ny+1)-float(ny)/2.
        xs = poly(ys,lc[*,i])

        sx = [sx,xs]
        sy = [sy,ys]
        so = [so,replicate(order[i],del)]
        
     endfor
     
     sx = sx[1:*]
     sy = sy[1:*]
     so = so[1:*]
     
     yrange = [min(sy,MAX=ymax),ymax]
     xrange = [min(sx,MAX=xmax),xmax]

     pos = mc_gridplotpos([0.1,0.1,0.95,0.95],[1,1],0.02,/SQUARE)
     plot,[1],[1],/NODATA,XRANGE=mc_bufrange(xrange,0.05), $
          YRANGE=mc_bufrange(yrange,0.05),FONT=0,POSITION=pos[*,0],$
          XTITLE='!9D!Xx (pixels)',YTITLE='!9D!Xy (pixels)',/XSTY,/YSTY,$
          TITLE='Zeroed Lines'
     
     for i = 0,norders-1 do begin
        
        z = where(so eq fix(orders[i]),cnt)
        if cnt ne 0 then begin
           
           plotsym,0,0.4,/FILL
           oplot,sx[z],sy[z],PSYM=8,COLOR=2+i
           
        endif
        
     endfor
     
     cb = rotate(rebin(findgen(norders)+2,norders,20),1)
     poss = [0.8,0.5,0.84,0.9]
     tvimage,cb,POSITION=poss
     plot,[1],[1],/NODATA,FONT=0,/NOERASE,$
          POSITION=poss,$
          YRANGE=[min(orders),max(orders)],/XSTY,XTICKS=1,$
          XRANGE=[0,1],$
          XTICKNAME=replicate(' ',10),$
          YTICKLEN=0.2,$
          YTITLE='Order Number'
     
  end
;
;===============================================================================
;
pro fitlinecoeffs_plotmodel,ncols,nrows,xvals,yvals,zvals,fit_zvals,zvalsimg,$
                            fit_zvalsimg,zrange,dtitle,mtitle, $
                            MODEINFO=modeinfo,GOODBAD=goodbad

  pos = mc_gridplotpos([0.1,0.08,0.95,0.93],[2,2],[0.03,0.05],/SQUARE)
  offset = 0.08
  pos[0,0] = pos[0,0]-offset
  pos[0,1] = pos[0,1]-offset
  pos[0,2] = pos[0,2]-offset
  pos[0,3] = pos[0,3]-offset

  pos[2,0] = pos[2,0]-offset
  pos[2,1] = pos[2,1]-offset
  pos[2,2] = pos[2,2]-offset
  pos[2,3] = pos[2,3]-offset

  if ncols ne nrows then begin
  
     if ncols gt nrows then begin
        
        scale = nrows/float(ncols)
        pos[3,0] = pos[3,0]-(pos[3,0]-pos[1,0])*scale
        pos[3,1] = pos[3,1]-(pos[3,1]-pos[1,1])*scale
        pos[3,2] = pos[3,2]-(pos[3,2]-pos[1,2])*scale
        pos[3,3] = pos[3,3]-(pos[3,3]-pos[1,3])*scale
        
        
     endif else begin
        
        scale = ncols/float(nrows)
        pos[2] = pos[2]-(pos[2]-pos[0])*scale        
        
     endelse

  endif
     
;  
; ======================== Do the data
;  
  plot,[1],[1],/NODATA,XRANGE=[0,ncols],YRANGE=[0,nrows],FONT=0, $
       POSITION=pos[*,0],YTITLE='Row (pixels)',/XSTY,/YSTY,TITLE=dtitle,$
       XTICKNAME=replicate(' ',10)
  
  mc_mkct,13,BOT=cbot
  ncolors = !d.n_colors < 255
  ncolors = ncolors-cbot

;  Get the zrange
  
  byt_zvalss = bytscl(zvals,TOP=ncolors-1,MIN=zrange[0],MAX=zrange[1]) + cbot

;  Plot the points
  
  plotsym,0,0.9,/FILL
  plots,xvals,yvals,PSYM=8
  plotsym,0,0.7,/FILL
  for i = 0,n_elements(xvals)-1 do plots,xvals[i],yvals[i],PSYM=8, $
                                         COLOR=byt_zvalss[i]

;  Get the band points
  
  if ~keyword_set(GOODBAD) then $
     goodbad = make_array(n_elements(xvals),VALUE=1,/INT)
  
  zbad = where(goodbad eq 0,cnt_bad,COMP=zgood,NCOMP=cnt_good)
  
  if cnt_bad ne 0 then plots,xvals[zbad],yvals[zbad],PSYM=6,SYMSIZE=1.5

;  Plot the orders

  if keyword_set(MODEINFO) then begin

     edgecoeffs = modeinfo.edgecoeffs
     orders = modeinfo.orders
     xranges = modeinfo.xranges
     
     for i = 0,n_elements(orders)-1 do begin
        
        x = findgen(xranges[1,i]-xranges[0,i]+1)+xranges[0,i]        
        topslit = poly(x,edgecoeffs[*,1,i])
        botslit = poly(x,edgecoeffs[*,0,i])
        !p.thick = 1
        oplot,x,botslit
        oplot,x,topslit

        midy = total(poly(xranges[0,i],edgecoeffs[*,1,i])+ $
                     poly(xranges[0,i],edgecoeffs[*,0,i]))/2.
        xyouts,xranges[0,i],midy,strtrim(orders[i]),FONT=0,ALIGNMENT=0.5, $
               CHARSIZE=0.7
        
     endfor
     !p.thick = 3
     
  endif

;  Do the image
  
  byt_zz = bytscl(zvalsimg,TOP=ncolors-1,MIN=zrange[0],MAX=zrange[1]) + cbot

;  ximgtool,zvalsimg,byt_zz
;  return
  zextrm = where(zvalsimg gt zrange[1] or zvalsimg lt zrange[0],bad)
  if bad ne 0 then byt_zz[zextrm] = 1
  
  tvimage,byt_zz,POSITION=pos[*,1],/NOINTERP  
  
  plot,[1],[1],/NODATA,XRANGE=[0,ncols],YRANGE=[0,nrows],FONT=0, $
       POSITION=pos[*,1],XTICKNAME=replicate(' ',10), $
       YTICKNAME=replicate(' ',10),/XSTY,/YSTY,TITLE='~Interpolation',/NOERASE

;  Plot the orders  
  
  if keyword_set(MODEINFO) then begin

     edgecoeffs = modeinfo.edgecoeffs
     orders = modeinfo.orders
     xranges = modeinfo.xranges
     
     for i = 0,n_elements(orders)-1 do begin
        
        x = findgen(xranges[1,i]-xranges[0,i]+1)+xranges[0,i]        
        topslit = poly(x,edgecoeffs[*,1,i])
        botslit = poly(x,edgecoeffs[*,0,i])
        !p.thick = 1
        oplot,x,botslit
        oplot,x,topslit

        midy = total(poly(xranges[0,i],edgecoeffs[*,1,i])+ $
                     poly(xranges[0,i],edgecoeffs[*,0,i]))/2.
        xyouts,xranges[0,i],midy,strtrim(orders[i]),FONT=0,ALIGNMENT=0.5, $
               CHARSIZE=0.7
        
     endfor
     !p.thick = 3
     
  endif
  
;  
; ======================== Do the model second
;  
  plot,[1],[1],/NODATA,XRANGE=[0,ncols],YRANGE=[0,nrows],FONT=0, $
       POSITION=pos[*,2],YTITLE='Row (pixels)',/XSTY,/YSTY,/NOERASE, $
       TITLE=' Model ('+mtitle+')',XTITLE='Column (pixels)'
  
  mc_mkct,13,BOT=cbot
  ncolors = !d.n_colors < 255
  ncolors = ncolors-cbot

  
  byt_zvalss = bytscl(fit_zvals,TOP=ncolors-1,MIN=zrange[0],MAX=zrange[1]) + $
               cbot

;  Plot the points
  
  plotsym,0,0.9,/FILL
  plots,xvals,yvals,PSYM=8
  plotsym,0,0.7,/FILL
  for i = 0,n_elements(xvals)-1 do plots,xvals[i],yvals[i],PSYM=8, $
                                         COLOR=byt_zvalss[i]
  
  if cnt_bad ne 0 then plots,xvals[zbad],yvals[zbad],PSYM=6,SYMSIZE=1.5

;  Plot the orders

  if keyword_set(MODEINFO) then begin

     edgecoeffs = modeinfo.edgecoeffs
     orders = modeinfo.orders
     xranges = modeinfo.xranges
     
     for i = 0,n_elements(orders)-1 do begin
        
        x = findgen(xranges[1,i]-xranges[0,i]+1)+xranges[0,i]        
        topslit = poly(x,edgecoeffs[*,1,i])
        botslit = poly(x,edgecoeffs[*,0,i])
        !p.thick = 1
        oplot,x,botslit
        oplot,x,topslit

        midy = total(poly(xranges[0,i],edgecoeffs[*,1,i])+ $
                     poly(xranges[0,i],edgecoeffs[*,0,i]))/2.
        xyouts,xranges[0,i],midy,strtrim(orders[i]),FONT=0,ALIGNMENT=0.5, $
               CHARSIZE=0.7
        
     endfor
     !p.thick = 3
     
  endif

;  Do the image
  
  byt_zz = bytscl(fit_zvalsimg,TOP=ncolors-1,MIN=zrange[0],MAX=zrange[1]) + cbot

  zextrm = where(fit_zvalsimg gt zrange[1] or fit_zvalsimg lt zrange[0],bad)
  if bad ne 0 then byt_zz[zextrm] = 1
  
  tvimage,byt_zz,POSITION=pos[*,3],/NOINTERP  
  
  plot,[1],[1],/NODATA,XRANGE=[0,ncols],YRANGE=[0,nrows],FONT=0, $
       POSITION=pos[*,3],YTICKNAME=replicate(' ',10),$
       /XSTY,/YSTY,TITLE=' Model ('+mtitle+')',/NOERASE,XTITLE='Column (pixels)'

;  Plot the orders  
  
  if keyword_set(MODEINFO) then begin

     edgecoeffs = modeinfo.edgecoeffs
     orders = modeinfo.orders
     xranges = modeinfo.xranges
     
     for i = 0,n_elements(orders)-1 do begin
        
        x = findgen(xranges[1,i]-xranges[0,i]+1)+xranges[0,i]        
        topslit = poly(x,edgecoeffs[*,1,i])
        botslit = poly(x,edgecoeffs[*,0,i])
        !p.thick = 1
        oplot,x,botslit
        oplot,x,topslit

        midy = total(poly(xranges[0,i],edgecoeffs[*,1,i])+ $
                     poly(xranges[0,i],edgecoeffs[*,0,i]))/2.
        xyouts,xranges[0,i],midy,strtrim(orders[i]),FONT=0,ALIGNMENT=0.5, $
               CHARSIZE=0.7
        
     endfor
     !p.thick = 3
     
  endif


;  Make the color bar
  
  npoints = 20
  del = (zrange[1]-zrange[0])/float(npoints)
  
  cb = rotate(rebin(findgen(npoints)*del+zrange[0],npoints),1)
  byt_cb = bytscl(cb,TOP=ncolors-1) + cbot

  poss = [pos[2,1]+0.1,pos[1,3],pos[2,1]+0.1+0.05,pos[3,1]]
  
  tvimage,byt_cb,POSITION=poss
  plot,[1],[1],/NODATA,FONT=0,/NOERASE,$
       POSITION=poss,$
       YRANGE=zrange,/XSTY,XTICKS=1,$
       XRANGE=[0,1],YSTY=1,$
       XTICKNAME=replicate(' ',10), $
       YTICKLEN=0.2

end
;
;===============================================================================
;
pro fitlinecoeffs_plotpoints,ncols,nrows,xvals,yvals,zvals,title,cbartitle, $
                             zrange,GOODBAD=goodbad,MODEINFO=modeinfo, $
                             ZEROLINE=zeroline

  pos = mc_gridplotpos([0.3,0.3,0.95,0.90],[1,1],0.02,/SQUARE)
  pos[0] = pos[0]-0.1
  pos[2] = pos[2]-0.1

  if ncols gt nrows then begin
     
     scale = nrows/float(ncols)
     pos[3] = pos[3]-(pos[3]-pos[1])*scale
     
     
  endif else begin

     if ncols ne nrows then begin
       
        scale = ncols/float(nrows)
        pos[2] = pos[2]-(pos[2]-pos[0])*scale        

     endif
        
  endelse


  plot,[1],[1],/NODATA,XRANGE=[0,ncols],YRANGE=[0,nrows],FONT=0, $
       POSITION=pos[*,0], $
       XTICKNAME=replicate(' ',10),$
       YTICKNAME=replicate(' ',10),$
       /XSTY,/YSTY,TITLE=title
  
  mc_mkct,13,BOT=cbot
  
  ncolors = !d.n_colors < 255
  ncolors = ncolors-cbot

  if ~keyword_set(GOODBAD) then $
     goodbad = make_array(n_elements(xvals),VALUE=1,/INT)

  zbad = where(goodbad eq 0,cnt_bad,COMP=zgood,NCOMP=cnt_good)

  zrange = [min(zvals[zgood],MAX=max),max]
  
  byt_zvalss = bytscl(zvals,TOP=ncolors-1,MIN=zrange[0],MAX=zrange[1]) + cbot
  
  plotsym,0,0.9,/FILL
  plots,xvals,yvals,PSYM=8
  plotsym,0,0.7,/FILL
  for i = 0,n_elements(xvals)-1 do plots,xvals[i],yvals[i],PSYM=8, $
                                         COLOR=byt_zvalss[i]

  if cnt_bad ne 0 then plots,xvals[zbad],yvals[zbad],PSYM=6,SYMSIZE=1.5

;  Plot orders

  if keyword_set(MODEINFO) then begin

     edgecoeffs = modeinfo.edgecoeffs
     orders = modeinfo.orders
     xranges = modeinfo.xranges
     
     for i = 0,n_elements(orders)-1 do begin
        
        x = findgen(xranges[1,i]-xranges[0,i]+1)+xranges[0,i]        
        topslit = poly(x,edgecoeffs[*,1,i])
        botslit = poly(x,edgecoeffs[*,0,i])
        !p.thick = 1
        oplot,x,botslit
        oplot,x,topslit
        
        midy = total(poly(xranges[0,i],edgecoeffs[*,1,i])+ $
                     poly(xranges[0,i],edgecoeffs[*,0,i]))/2.
        xyouts,xranges[0,i],midy,strtrim(orders[i]),FONT=0,ALIGNMENT=0.5, $
               CHARSIZE=0.7
        
     endfor
     !p.thick = 3
     
  endif

;  Make the color bar
  
  min = min(zvals,MAX=max)
  npoints = 20
  del = (max-min)/float(npoints)
  
  cb = rotate(rebin(findgen(npoints)*del+min,npoints),1)
  byt_cb = bytscl(cb,TOP=ncolors-1) + cbot
  poss = [pos[2]+0.12,pos[1],pos[2]+0.12+0.05,pos[3]]
  
  tvimage,byt_cb,POSITION=poss
  plot,[1],[1],/NODATA,FONT=0,/NOERASE,$
       POSITION=poss,$
       YRANGE=[min(zvals),max(zvals)],/XSTY,XTICKS=1,$
       XRANGE=[0,max],YSTY=1,$
       XTICKNAME=replicate(' ',10), $
       YTICKLEN=0.2,$
       YTITLE=cbartitle

;  Do the marginalizations

;  Bottom first
  
  offset = 0.04
  width = 0.17
  posbot = [pos[0],pos[1]-offset-width,pos[2],pos[1]-offset]

  plot,[1],[1],POSITION=posbot,/NOERASE,FONT=0,$
       XRANGE=[0,ncols],/YSTY,$
       YRANGE=mc_bufrange([min(zvals[zgood]),max(zvals[zgood])],0.1),/XSTY, $
       YTICK_GET=val,$
       XTITLE='Column (pixels)'

  if keyword_set(ZEROLINE) then plots,!x.crange,[0,0],LINESTYLE=1
  
  for i = 0,n_elements(xvals)-1 do begin

     if zvals[i] gt !y.crange[1] or zvals[i] lt !y.crange[0] then continue

     plotsym,0,0.9,/FILL
     plots,xvals[i],zvals[i],PSYM=8
     plotsym,0,0.7,/FILL
     plots,xvals[i],zvals[i],PSYM=8,COLOR=byt_zvalss[i]

  endfor

  if cnt_bad ne 0 then begin
     oplot,xvals[zbad],zvals[zbad],PSYM=6,SYMSIZE=1.5
  endif
     
;  Next the left
  
  
  offset = 0.04
  width = width*float(!d.y_vsize)/!d.x_vsize
  posleft = [pos[0]-offset-width,pos[1],pos[0]-offset,pos[3]]
  
  plot,[1],[1],POSITION=posleft,/NOERASE,FONT=0,$
       YRANGE=[0,nrows],/YSTY,$
       XRANGE=mc_bufrange([max(zvals[zgood]),min(zvals[zgood])],0.1),/XSTY, $
       YTITLE='Row (pixels)', $
       XTICKS=1,XMINOR=2,XTICKV=[val[0],val[n_elements(val)-1]]

  if keyword_set(ZEROLINE) then plots,[0,0],!y.crange,LINESTYLE=1
  
  for i = 0,n_elements(xvals)-1 do begin

     if zvals[i] gt !x.crange[0] or zvals[i] lt !x.crange[1] then continue
     plotsym,0,0.9,/FILL
     plots,zvals[i],yvals[i],PSYM=8
     plotsym,0,0.7,/FILL
     plots,zvals[i],yvals[i],PSYM=8,COLOR=byt_zvalss[i]

  endfor

  if cnt_bad ne 0 then begin
     oplot,zvals[zbad],yvals[zbad],PSYM=6,SYMSIZE=1.5
  endif
     
end
;
;===============================================================================
;
pro mc_fitlinecoeffs2d,lstruc,fitdeg,c1coeff,c2coeff,WEIGHT=weight, $
                       QAPLOT=qaplot,MODEINFO=modeinfo,CANCEL=cancel

  cancel = 0

;  Get some useful information
  
  lc = lstruc.linecoeffs
  linedeg = n_elements(lc[*,0])-1

  nlines = n_elements(lstruc)
  order  = lstruc.order
  orders = order[uniq(order,sort(order))]
  norders = n_elements(orders)
  
  xbot   = lstruc.xbot
  ybot   = lstruc.ybot
  xtop   = lstruc.xtop
  ytop   = lstruc.ytop
  xmid   = lstruc.xmid
  ymid   = lstruc.ymid
  
;  Correct the line coefficients relative to the middle of the slit
  
  for i = 0,nlines-1 do begin

        case linedeg of

           1: tmp = [0,lc[1,i]]
           
           2: tmp = [0,lc[1,i]+2*lc[2,i]*ymid[i],lc[2,i]]
                      
        endcase
        
        lc[*,i] = reform(tmp)
        
  endfor
  
;  Fit the c1 coefficient
  
  c1 = reform((lc)[1,*])

  c1coeff = mc_robustpoly2d(xmid,ymid,c1,fitdeg[0],fitdeg[1],3.5,0.01,/SILENT, $
;                            ZERR=weight,$
                            OGOODBAD=ogoodbad_c1)
  fit_c1 = mc_poly2d(xmid,ymid,fitdeg[0],fitdeg[1],c1coeff)
  
;  Now fit the c2 coefficient if provided
  
  if linedeg eq 2 then begin
     
     c2 = reform((lc)[2,*])
     c2coeff = mc_robustpoly2d(xmid,ymid,c2,fitdeg[2],fitdeg[3],3.5,0.01, $
                               ZERR=weight,/SILENT,OGOODBAD=ogoodbad_c2)
     fit_c2 = mc_poly2d(xmid,ymid,fitdeg[2],fitdeg[3],c2coeff)
     
  endif

;  Get set up for the QA plots if requested
  
  if keyword_set(QAPLOT) then begin

     c1label = 'deg!DX!N='+strtrim(fitdeg[0],2)+', deg!DY!N='+ $
               strtrim(fitdeg[1],2)
              
;  Set up the postscript
     
     !x.thick=3
     !y.thick=3
     !p.thick=3

     mc_mkct
     mc_ldcolortempct,norders,/INVERT
     mc_setpsdev,qaplot.prefix+'_2DCoeffFits.ps',11,8.5,/LANDSCAPE, $
                 FONT=13,BITS=8

;  Plot the lines
     
     fitlinecoeffs_plotlines,ytop,ybot,order,lc,orders

;  Plot the c1 points, with marginals

     fitlinecoeffs_plotpoints,qaplot.ncols,qaplot.nrows,xmid,ymid,c1, $
                              'Coefficient c1!Dzline!N','',zrange, $
                              MODEINFO=modeinfo

;  Now generate the interpolation of these data.  You have to shift
;  the xx points relative to the minimum xrange because
;  griddata doesn't take a starting x value but rather assumes zero.
;  **This part also assumes you are doing the entire y size of the array.**

     zgood = where(ogoodbad_c1 eq 1)
;     triangulate, xmid[zgood],ymid[zgood],tri
;     forprint, xmid-qaplot.xrange[0],ymid,c1,ogoodbad_c1,TEXT=2

     
     tmp = griddata(xmid[zgood]-qaplot.xrange[0],ymid[zgood],c1[zgood], $
;                    /NEAREST,$
;                    MIN_POINTS=3,$
                    /POLYNOMIAL_REGRESSION,POWER=2,$
;                    TRIANGLES=tri, $
                    MISSING=!values.f_nan,$
                    DIMENSION=[qaplot.xrange[1]-qaplot.xrange[0]+1, $
                               qaplot.nrows],DELTA=[1,1])

;  Now slip this smaller array into a larger array so it can be easily
;  displayed.
     
     c1img = fltarr(qaplot.ncols,qaplot.nrows)
     c1img[qaplot.xrange[0]:qaplot.xrange[1],*] = tmp

;     print, size(tmp)
;     print, size(c1img)
;     ximgtool,tmp,c1img
;     return
     
;  Now generate the model surface
     
     minx = qaplot.xrange[0]
     maxx = qaplot.xrange[1]
     ncols = maxx-minx+1

     x = rebin(indgen(ncols),ncols,qaplot.nrows)+minx
     y = rebin(reform(indgen(qaplot.nrows),1,qaplot.nrows),ncols, $
               qaplot.nrows)
     
     x = reform(temporary(x),long(ncols)*qaplot.nrows)
     y = reform(temporary(y),long(ncols)*qaplot.nrows)     
     
     tmp = mc_poly2d(x,y,total(fitdeg[0]),total(fitdeg[1]),c1coeff)
     tmp = reform(temporary(tmp),ncols,qaplot.nrows)

     fit_c1img = fltarr(qaplot.ncols,qaplot.nrows)
     fit_c1img[qaplot.xrange[0]:qaplot.xrange[1],*] = tmp

;  Now do the plot 
     
     fitlinecoeffs_plotmodel,qaplot.ncols,qaplot.nrows,xmid,ymid,c1,fit_c1,$
                             c1img,fit_c1img,zrange,'Coefficient c1!Dzline!N', $
                             'deg!DX!N='+strtrim(fitdeg[0],2)+', deg!DY!N='+ $
                             strtrim(fitdeg[1],2),MODEINFO=modeinfo, $
                             GOODBAD=ogoodbad_c1

;  Plot the percent residuals

     resid = (c1-fit_c1)/fit_c1*100
     fitlinecoeffs_plotpoints,qaplot.ncols,qaplot.nrows,xmid,ymid,resid, $
                              'Percent Fractional Residual of c1!Dzline!N fit',$
                              '',MODEINFO=modeinfo,GOODBAD=ogoodbad_c1,/ZEROLINE
     

     if linedeg eq 2 then begin

;  Plot the c2 points, with marginals
     
        fitlinecoeffs_plotpoints,qaplot.ncols,qaplot.nrows,xmid,ymid,c2, $
                                 'Coefficient c2!Dzline!N','',zrange, $
                                 MODEINFO=modeinfo
        
;  Now generate the interpolation of these data.  You have to shift
;  the xx points relative to the minimum xrange because
;  griddata doesn't take a starting x value but rather assumes zero.
;  **This part also assumes you are doing the entire y size of the array.**
        
        zgood = where(ogoodbad_c2 eq 1)
;        triangulate, xmid[zgood],ymid[zgood],tri
        
        tmp = griddata(xmid[zgood]-qaplot.xrange[0],ymid[zgood],c2[zgood], $
;                       TRIANGLES=tri,$
                       /POLYNOMIAL_REGRESSION,POWER=2, $
                       DIMENSION=[qaplot.xrange[1]-qaplot.xrange[0]+1, $
                                  qaplot.nrows],DELTA=[1,1])
        
;  Now slip this smaller array into a larger array so it can be easily
;  displayed.
        
        c2img = fltarr(qaplot.ncols,qaplot.nrows)
        c2img[qaplot.xrange[0]:qaplot.xrange[1],*] = tmp

;  Now generate the model surface
     
        tmp = mc_poly2d(x,y,total(fitdeg[2]),total(fitdeg[3]),c2coeff)
        tmp = reform(temporary(tmp),ncols,qaplot.nrows)

        fit_c2img = fltarr(qaplot.ncols,qaplot.nrows)
        fit_c2img[qaplot.xrange[0]:qaplot.xrange[1],*] = tmp
        
;  Now do the plot 
        
        fitlinecoeffs_plotmodel,qaplot.ncols,qaplot.nrows,xmid,ymid,c2,fit_c2,$
                                c2img,fit_c2img,zrange, $
                                'Coefficient c2!Dzline!N', $
                                'deg!DX!N='+strtrim(fitdeg[2],2)+ $
                                ', deg!DY!N='+strtrim(fitdeg[3],2), $
                                MODEINFO=modeinfo,GOODBAD=ogoodbad_c2

;  Plot the percent residuals

        resid = (c2-fit_c2)/fit_c2*100
        fitlinecoeffs_plotpoints,qaplot.ncols,qaplot.nrows,xmid,ymid,resid, $
                                 'Percent Fractional Residual of ' + $
                                 'c2!Dzline!N fit','',MODEINFO=modeinfo, $
                                 GOODBAD=ogoodbad_c2,/ZEROLINE
     
     endif
     
     mc_setpsdev,/CLOSE,/CONVERT,/ERASE

  endif
  
 
end
