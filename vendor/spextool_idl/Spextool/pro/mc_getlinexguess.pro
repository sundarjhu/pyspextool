;+
; NAME:
;     mc_getlinexguess
;
; PURPOSE:
;     To determine the guess position for lines 
;
; CALLING SEQUENCE:
;     result = mc_getlinexguess(wspec,xranges,orders,lineinfo,CANCEL=cancel)
;
; INPUTS:
;     wspec    - A [nwave,norders] array giving the wavelengths of
;                each order, e.g. wave=wspec[*,0].
;     xranges  - An array [2,norders] of column numbers where the
;                orders are completely on the array
;     orders   - An [norders] array giving the order numbers.
;     lineinfo - A structure with the following tags:
;                lineinfo.order   = order numbers (integer)
;                lineinfo.swave   = wavelengths (string)
;                lineinfo.id      = line IDs (string)
;                lineinfo.wwin    = fit window (in units of swave)
;                lineinfo.fittype = fit type (0=gaussian, 1=Lotentzian)
;                lineinfo.nterms  = Number of terms (3=basic,
;                                   4=basic+constant,5=basic+line) 
;
;                Typically generated by mc_readlinelist.pro.
;
; OPTIONAL INPUTS:
;     None
;
; KEYWORD PARAMETERS:
;     CANCEL - Set on return if there is a problem.
;
; OUTPUTS:
;     result - A structure with the following tags:
;              lineinfo.order   = order numbers (integer)
;              lineinfo.swave   = wavelengths (string)
;              lineinfo.id      = line IDs (string)
;              lineinfo.wwin    = fit window (in units of swave)
;              lineinfo.fittype = fit type (0=gaussian, 1=Lotentzian)
;              lineinfo.nterms  = Number of terms (3=basic,
;                                 4=basic+constant,5=basic+line) 
;              lineinfo.xguess  = x positions of lines in wspec.
;              lineinfo.xwin    = The fit window in units of pixels.
;
; OPTIONAL OUTPUTS:
;     None
;
; COMMON BLOCKS:
;     None
;
; RESTRICTIONS:
;     None
;
; DEPENDENCIES:
;     Spextool library (and its dependencies)
;
; PROCEDURE:
;     For each line in lineinfo, the program determines the pixel
;     position given the wspec arrays.
;
; EXAMPLES:
;     NA
;
; MODIFICATION HISTORY:
;     2017-10-01: Written by M. Cushing, University of Toledo
;-
function mc_getlinexguess,wspec,xranges,orders,lineinfo,CANCEL=cancel

  cancel = 0

;  Check parameters

  if n_params() lt 1 then begin
     
     print, 'Syntax - result = mc_getlinexguess(wspec,xranges,orders,$'
     print, '                                   lineinfo,CANCEL=cancel)'
     cancel = 1
     return,-1
     
  endif
  cancel = mc_cpar('mc_getlinexguess',wspec,1,'Wspec',[4,5],[1,2])
  if cancel then return,-1
  cancel = mc_cpar('mc_getlinexguess',xranges,2,'Xranges',[2,3,4,5],[1,2])
  if cancel then return,-1
  cancel = mc_cpar('mc_getlinexguess',orders,3,'Orders',[2,3],[1])
  if cancel then return,-1
  cancel = mc_cpar('mc_getlinexguess',lineinfo,4,'Lineinfo',[8])
  if cancel then return,-1       

;  Get info and get set up  

  nlines = n_elements(lineinfo)
  norders = n_elements(orders)
  
  lxguesses = fltarr(nlines,/NOZERO)
  lxwins    = intarr(nlines,/NOZERO)
  
  start = 0
  for i = 0,norders-1 do begin

;  Find the lines that are in the order
     
     z = where(lineinfo.order eq orders[i],n_olines)
     if n_olines eq 0 then continue

;  Get the spectrum's wavelength and x arrays

        w = wspec[*,i]
        x = findgen(n_elements(wspec[*,i]))+xranges[0,i]
        zgood = where(finite(w) eq 1)
        w = w[zgood]
        x = x[zgood]

;  Find the lines and window positions
        
        linterp,w,x,(double(lineinfo[z].swave)),xguess
        linterp,w,x,(double(lineinfo[z].swave))-lineinfo[z].wwin/2.,left
        linterp,w,x,(double(lineinfo[z].swave))+lineinfo[z].wwin/2.,right

;  Store the results
        
        lxguesses[start:(start+n_olines-1)] = xguess
        lxwins[start:(start+n_olines-1)] = round(right-left)

        start = start+n_olines
        
  endfor

;  Now tack these two arrays onto your line information structure

  str = lineinfo[0]
  str = create_struct(str,'xguess',0.0,'xwin',0.0)
  str = replicate(str,nlines)
  struct_assign, lineinfo, str

  str.xguess = lxguesses
  str.xwin = lxwins

  return, str
  
end
